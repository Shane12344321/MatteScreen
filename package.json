{
  "name": "mattescreen",
  "version": "1.0.0",
  "description": "A free, open-source desktop overlay that gives your screen a soft, paper-like matte texture to reduce glare and contrast. A free alternative to Paperman.",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "cc.mattescreen.app",
    "productName": "MatteScreen",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": ["dmg", "zip"],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "MatteScreen"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis", "portable"]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage"],
      "category": "Utility"
    }
  }
}
